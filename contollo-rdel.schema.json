{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://larrycarter.github.io/Contollo.Rdel.ZipRunner/contollo-rdel.schema.json",
  "title": "Contollo RDEL Manifest",
  "type": "object",
  "required": [
    "Name",
    "Description",
    "Target",
    "Commands"
  ],
  "properties": {
    "Name": {
      "type": "string",
      "minLength": 1
    },
    "Description": {
      "type": "string"
    },
    "Target": {
      "type": "string",
      "enum": [
        "solution",
        "selected-project"
      ]
    },
    "Commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ValidationProfile": {
      "type": "string",
      "enum": [
        "GitOnly",
        "DotNetCli",
        "VisualStudioMsBuild",
        "Custom"
      ]
    },
    "DocumentationOperations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "Type",
          "Target",
          "Source"
        ],
        "properties": {
          "Type": {
            "type": "string",
            "enum": [
              "Append"
            ]
          },
          "Target": {
            "type": "string"
          },
          "Source": {
            "type": "string"
          },
          "Section": {
            "type": "string"
          },
          "Id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "ExpectedAfterApply": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}