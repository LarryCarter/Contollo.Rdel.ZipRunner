{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RDEL Engineering Memory",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "summary",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "problem": {
      "type": "string"
    },
    "rootCause": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}